{
  "name": "tzadik",
  "version": "0.1.0",
  "description": "CLI for tzadik.js setup, analysis, and reports.",
  "type": "module",
  "bin": {
    "tzadik": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --banner:js \"#!/usr/bin/env node\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@tzadik/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "typescript": "^5.8.3"
  }
}
