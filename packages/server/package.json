{
  "name": "@tzadik/server",
  "version": "0.1.0",
  "description": "Small server-side helpers for receiving tzadik.js RUM events.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tzadik/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
